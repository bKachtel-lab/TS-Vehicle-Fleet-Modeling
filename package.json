{
  "name": "web-objectmodel-lab",
  "version": "0.0.1",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest  run --config vitest.config.ts",
    "test:watch": "vitest watch",
    "test:coverage": "vitest watch --config vitest.config.ts --coverage.enabled --coverage.all",
    "test:ci": "vitest run --config vitest.config.ts --coverage.enabled --coverage.all --no-color",
    "prebuild": "rm -rf dist/*",
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint 'src/**/*.{ts,tsx,js,jsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx,js,jsx}' --fix",
    "format": "prettier 'src/**/*.{ts,tsx,js,jsx,json,md}' --write",
    "format:check": "prettier 'src/**/*.{ts,tsx,js,jsx,json,md}' --check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitest/coverage-v8": "^3.0.6",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "prettier": "^3.5.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.0.6"
  }
}
